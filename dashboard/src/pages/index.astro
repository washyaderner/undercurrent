---
import Layout from '../layouts/Layout.astro';

const API = 'https://undercurrent.washyaderner.workers.dev/api';

const [statsRes, trendsRes, signalsRes, psychosisRes, voicesRes, actionsRes] = await Promise.all([
  fetch(`${API}/stats`),
  fetch(`${API}/trends?days=7`),
  fetch(`${API}/signals?limit=20&min_originality=0.4`),
  fetch(`${API}/psychosis`),
  fetch(`${API}/voices`),
  fetch(`${API}/actions?status=pending`),
]);

const stats = await statsRes.json();
const { trends: rawTrends } = await trendsRes.json();
const { signals } = await signalsRes.json();
const { highest_psychosis, most_genuine } = await psychosisRes.json();
const { voices } = await voicesRes.json();
const { actions = [] } = await actionsRes.json().catch(() => ({ actions: [] }));

const trends = (rawTrends as any[]).map((t: any) => {
  const items = (t.top_items || []) as any[];
  const genuine = items.filter((i: any) => i.psychosis_score < 0.4);
  const withBriefs = genuine.filter((i: any) =>
    i.implementation_brief && i.implementation_brief !== 'No actionable implementation path.'
  );
  const tagSet = new Set();
  genuine.forEach((i: any) => {
    try { JSON.parse(i.topic_tags || '[]').forEach((tag: string) => tagSet.add(tag)); } catch {}
  });
  return {
    ...t,
    genuine,
    withBriefs,
    allTags: Array.from(tagSet) as string[],
    platforms: JSON.parse(t.platforms || '[]'),
    authors: JSON.parse(t.top_authors || '[]'),
  };
});

function classColor(c: string) {
  if (c === 'breakout') return 'text-red bg-red/10 border-red/30';
  if (c === 'rising') return 'text-amber bg-amber/10 border-amber/30';
  return 'text-cyan bg-cyan/10 border-cyan/30';
}

function scoreColor(score: number) {
  if (score >= 0.7) return 'bg-red';
  if (score >= 0.4) return 'bg-amber';
  return 'bg-green';
}

function psychosisColor(score: number) {
  if (score >= 0.6) return 'text-red';
  if (score >= 0.3) return 'text-amber';
  return 'text-green';
}

function shieldColor(score: number) {
  if (score > 0.5) return 'text-red';
  if (score > 0.2) return 'text-amber';
  return 'text-green';
}

function shieldLabel(score: number) {
  if (score > 0.5) return 'danger';
  if (score > 0.2) return 'review';
  return 'clean';
}

function riskColor(level: string) {
  if (level === 'approve') return 'text-red bg-red/10 border-red/30';
  if (level === 'suggest') return 'text-amber bg-amber/10 border-amber/30';
  return 'text-green bg-green/10 border-green/30';
}

function riskLabel(level: string) {
  if (level === 'approve') return 'needs approval';
  if (level === 'suggest') return 'suggested';
  return 'auto-approved';
}

function sourceIcon(source: string) {
  if (source === 'hn') return 'HN';
  if (source === 'reddit') return 'RD';
  if (source === 'github') return 'GH';
  return source.toUpperCase().slice(0, 2);
}

function sourceBg(source: string) {
  if (source === 'hn') return 'bg-amber/20 text-amber';
  if (source === 'reddit') return 'bg-purple/20 text-purple';
  if (source === 'github') return 'bg-cyan/20 text-cyan';
  return 'bg-surface-hover text-text-dim';
}
---

<Layout title="Undercurrent - AI Trend Intelligence">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-baseline gap-3 mb-2 hero-enter hero-enter-1">
        <h1 class="text-4xl font-bold text-cyan tracking-tight">undercurrent</h1>
        <span class="text-text-dim text-sm">v0.1</span>
      </div>
      <p class="text-text-dim text-sm max-w-2xl hero-enter hero-enter-2">
        AI trend intelligence. Scans HN, Reddit, and GitHub every 6 hours. Filters AI-generated hype.
        Surfaces the people who were talking about it first.
      </p>
      <!-- Setup CTA (hidden when wizard complete) -->
      <div id="setup-cta" class="mt-4 hidden">
        <a href="/setup" class="inline-flex items-center gap-2 text-sm px-4 py-2 bg-cyan/10 text-cyan border border-cyan/30 rounded-lg hover:bg-cyan/20 hover-lift">
          <span class="w-2 h-2 rounded-full bg-cyan pulse-slow"></span>
          Configure your stack for personalized signals
        </a>
      </div>
      <!-- Stack badge (shown when wizard complete) -->
      <div id="stack-badge" class="mt-4 hidden">
        <div class="inline-flex items-center gap-2 text-xs px-3 py-2 bg-cyan/10 text-cyan border border-cyan/20 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan"></span>
          <span id="stack-summary"></span>
          <a href="/setup" class="text-text-dim hover:text-cyan ml-1">edit</a>
        </div>
      </div>
    </header>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12 hero-enter hero-enter-3">
      <div class="bg-surface border border-border rounded-lg p-4">
        <div class="text-text-dim text-xs uppercase tracking-wider mb-1">Signals Tracked</div>
        <div class="text-2xl font-bold text-cyan">{stats.total_items}</div>
      </div>
      <div class="bg-surface border border-border rounded-lg p-4">
        <div class="text-text-dim text-xs uppercase tracking-wider mb-1">Analyzed</div>
        <div class="text-2xl font-bold text-cyan">{stats.analyzed_items}</div>
      </div>
      <div class="bg-surface border border-border rounded-lg p-4">
        <div class="text-text-dim text-xs uppercase tracking-wider mb-1">Quality Voices</div>
        <div class="text-2xl font-bold text-cyan">{stats.quality_voices}</div>
      </div>
      <div class="bg-surface border border-border rounded-lg p-4">
        <div class="text-text-dim text-xs uppercase tracking-wider mb-1">Trends Today</div>
        <div class="text-2xl font-bold text-cyan">{stats.trends_today}</div>
      </div>
    </div>

    <!-- Recommended Actions -->
    {actions.length > 0 && (
      <section class="mb-12" id="actions-section">
        <h2 class="text-lg font-semibold text-text mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-green pulse-slow"></span>
          Recommended Actions
          <span class="text-xs text-text-dim font-normal ml-1">({actions.length} pending)</span>
        </h2>
        <div class="grid gap-3">
          {actions.map((a: any) => (
            <div class="bg-surface border border-border rounded-lg p-4 hover-glow action-card" data-action-id={a.id}>
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-2">
                    <span class={`text-xs px-2 py-1 rounded-full border ${riskColor(a.risk_level)}`}>
                      {riskLabel(a.risk_level)}
                    </span>
                    {a.source && (
                      <span class={`text-xs px-2 py-1 rounded ${sourceBg(a.source)}`}>
                        {sourceIcon(a.source)}
                      </span>
                    )}
                    {a.title && (
                      a.item_url ? (
                        <a href={a.item_url} target="_blank" rel="noopener" class="text-xs text-text-dim hover:text-cyan truncate">
                          {a.title}
                        </a>
                      ) : (
                        <span class="text-xs text-text-dim truncate">{a.title}</span>
                      )
                    )}
                  </div>
                  <p class="text-sm text-text mb-1 max-w-[65ch]">{a.action_description}</p>
                  <p class="text-xs text-text-dim">{a.reason}</p>
                </div>
                <div class="flex gap-2 shrink-0">
                  <button
                    class="action-btn text-xs px-3 py-2 bg-green/10 text-green border border-green/30 rounded hover:bg-green/20 hover-lift cursor-pointer"
                    data-action-id={a.id}
                    data-verb="approve"
                  >
                    Approve
                  </button>
                  <button
                    class="action-btn text-xs px-3 py-2 bg-surface-hover text-text-dim border border-border rounded hover:bg-red/10 hover:text-red hover:border-red/30 hover-lift cursor-pointer"
                    data-action-id={a.id}
                    data-verb="dismiss"
                  >
                    Dismiss
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Trends Section -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-text mb-4 flex items-center gap-2 hero-enter hero-enter-4">
        <span class="w-2 h-2 rounded-full bg-amber pulse-slow"></span>
        Emerging Trends
      </h2>
      {trends.length === 0 ? (
        <p class="text-text-dim text-sm">No trends detected yet. Data accumulates over 7+ days.</p>
      ) : (
        <div class="grid gap-6">
          {trends.map((t: any) => (
              <div class="bg-surface border border-border rounded-lg overflow-hidden hover-glow">
                <div class="p-6 pb-4">
                  <div class="flex items-start justify-between mb-2">
                    <div class="flex items-center gap-3">
                      <span class="text-lg font-semibold text-text tracking-tight">{t.topic}</span>
                      <span class={`text-xs px-2 py-1 rounded-full border ${classColor(t.classification)}`}>
                        {t.classification}
                      </span>
                    </div>
                    <div class="flex items-center gap-4">
                      <span class="absorption-score hidden text-xs" data-topic={t.topic}></span>
                      <div class="text-right">
                        <div class="text-sm font-semibold text-cyan">{t.emergence_score.toFixed(1)}</div>
                        <div class="text-xs text-text-dim">emergence</div>
                      </div>
                    </div>
                  </div>
                  <div class="flex flex-wrap gap-4 text-xs text-text-dim">
                    <span>{t.mention_count} mentions</span>
                    <span>velocity: {typeof t.velocity === 'number' ? t.velocity.toFixed(1) : t.velocity}x</span>
                    <span>platforms: {t.platforms.join(', ')}</span>
                  </div>
                </div>

                {t.genuine.length > 0 && (
                  <div class="px-6 pb-3">
                    <div class="space-y-2">
                      {t.genuine.slice(0, 3).map((item: any) => (
                        <div class="bg-deep/50 rounded-lg p-3 border border-border/50">
                          <div class="flex items-start justify-between gap-3 mb-1">
                            <div class="flex items-center gap-2 min-w-0">
                              <span class={`text-xs px-2 py-1 rounded shrink-0 ${sourceBg(item.source)}`}>
                                {sourceIcon(item.source)}
                              </span>
                              {item.url ? (
                                <a href={item.url} target="_blank" rel="noopener" class="text-xs font-medium text-text hover:text-cyan truncate">
                                  {item.title}
                                </a>
                              ) : (
                                <span class="text-xs font-medium text-text truncate">{item.title}</span>
                              )}
                            </div>
                            <div class="flex gap-2 text-xs text-text-dim shrink-0">
                              <span class="text-amber">O:{(item.originality_score * 100).toFixed(0)}</span>
                              <span class="text-cyan">D:{(item.technical_depth * 100).toFixed(0)}</span>
                              {item.shield_score > 0.2 && (
                                <span class={shieldColor(item.shield_score)} title={`Shield: ${shieldLabel(item.shield_score)}`}>
                                  S:{(item.shield_score * 100).toFixed(0)}
                                </span>
                              )}
                            </div>
                          </div>
                          {item.analysis_summary && (
                            <p class="text-xs text-text-dim leading-relaxed mt-1 max-w-[65ch]">{item.analysis_summary}</p>
                          )}
                          {item.author && (
                            <div class="mt-2 flex items-center gap-2">
                              <span class="text-xs text-purple">{item.author}</span>
                              {item.upvotes > 0 && <span class="text-xs text-text-dim">{item.upvotes} up</span>}
                              {item.comments > 0 && <span class="text-xs text-text-dim">{item.comments} cmt</span>}
                              {item.stars > 0 && <span class="text-xs text-text-dim">{item.stars} star</span>}
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {t.withBriefs.length > 0 && (
                  <div class="px-6 pb-3">
                    <div class="text-xs text-text-dim uppercase tracking-wider mb-2">What practitioners are doing</div>
                    <div class="space-y-1.5">
                      {t.withBriefs.slice(0, 2).map((item: any) => (
                        <div class="text-xs text-text leading-relaxed bg-cyan/5 border border-cyan/10 rounded-lg p-3">
                          {(item.implementation_brief as string).slice(0, 250)}{(item.implementation_brief as string).length > 250 ? '...' : ''}
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                <div class="px-6 pb-4 pt-1">
                  {t.allTags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-3">
                      {t.allTags.slice(0, 8).map((tag: string) => (
                        <span class="text-xs px-2 py-1 bg-surface-hover text-text-dim rounded border border-border">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  <div class="flex items-center justify-between">
                    {t.authors.length > 0 ? (
                      <div class="flex flex-wrap gap-2">
                        {t.authors.slice(0, 5).map((a: string) => (
                          <span class="text-xs px-2 py-1 bg-purple/10 text-purple rounded-full border border-purple/20">
                            {a}
                          </span>
                        ))}
                      </div>
                    ) : <div />}
                    <button
                      class="kit-download text-xs px-3 py-2 bg-cyan/10 text-cyan border border-cyan/30 rounded hover:bg-cyan/20 hover-lift shrink-0 cursor-pointer"
                      data-topic={t.topic}
                    >
                      Download Full Kit .md
                    </button>
                  </div>
                </div>
              </div>
          ))}
        </div>
      )}
    </section>

    <div class="sig-divider my-16"></div>

    <!-- Psychosis Filter Section -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-text mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-red"></span>
        AI Psychosis Filter
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Highest psychosis -->
        <div>
          <h3 class="text-sm text-red mb-3 uppercase tracking-wider">Detected Hype</h3>
          <div class="space-y-2">
            {highest_psychosis.slice(0, 8).map((item: any) => (
              <div class="bg-surface border border-border rounded-lg p-3 flex items-start gap-3">
                <span class={`text-xs font-mono font-bold mt-1 ${psychosisColor(item.psychosis_score)}`}>
                  {(item.psychosis_score * 100).toFixed(0)}%
                </span>
                <div class="flex-1 min-w-0">
                  <div class="text-sm text-text truncate">
                    {item.url ? (
                      <a href={item.url} target="_blank" rel="noopener" class="hover:text-cyan">
                        {item.title}
                      </a>
                    ) : item.title}
                  </div>
                  <div class="flex gap-2 mt-1">
                    <span class={`text-xs px-2 py-1 rounded ${sourceBg(item.source)}`}>
                      {sourceIcon(item.source)}
                    </span>
                    {item.author && <span class="text-xs text-text-dim">{item.author}</span>}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Most genuine -->
        <div>
          <h3 class="text-sm text-green mb-3 uppercase tracking-wider">Verified Genuine</h3>
          <div class="space-y-2">
            {most_genuine.slice(0, 8).map((item: any) => (
              <div class="bg-surface border border-border rounded-lg p-3 flex items-start gap-3">
                <span class="text-xs font-mono font-bold mt-1 text-green">
                  {((1 - item.psychosis_score) * 100).toFixed(0)}%
                </span>
                <div class="flex-1 min-w-0">
                  <div class="text-sm text-text truncate">
                    {item.url ? (
                      <a href={item.url} target="_blank" rel="noopener" class="hover:text-cyan">
                        {item.title}
                      </a>
                    ) : item.title}
                  </div>
                  <div class="flex gap-2 mt-1">
                    <span class={`text-xs px-2 py-1 rounded ${sourceBg(item.source)}`}>
                      {sourceIcon(item.source)}
                    </span>
                    {item.author && <span class="text-xs text-text-dim">{item.author}</span>}
                    <span class="text-xs text-amber">orig: {(item.originality_score * 100).toFixed(0)}%</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Signals Section -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-text mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-cyan"></span>
        Latest Signals
      </h2>
      <div class="grid gap-3">
        {signals.slice(0, 12).map((s: any) => {
          const tags = JSON.parse(s.topic_tags || '[]');
          return (
            <div class="bg-surface border border-border rounded-lg p-4 hover-glow">
              <div class="flex items-start justify-between gap-4 mb-2">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <span class={`text-xs px-2 py-1 rounded ${sourceBg(s.source)}`}>
                      {sourceIcon(s.source)}
                    </span>
                    {s.url ? (
                      <a href={s.url} target="_blank" rel="noopener" class="text-sm font-medium text-text hover:text-cyan truncate">
                        {s.title}
                      </a>
                    ) : (
                      <span class="text-sm font-medium text-text truncate">{s.title}</span>
                    )}
                  </div>
                </div>
                <div class="flex gap-3 text-xs text-text-dim shrink-0">
                  <span title="Psychosis score" class={psychosisColor(s.psychosis_score)}>
                    P:{(s.psychosis_score * 100).toFixed(0)}
                  </span>
                  <span title="Originality" class="text-amber">
                    O:{(s.originality_score * 100).toFixed(0)}
                  </span>
                  <span title="Technical depth" class="text-cyan">
                    D:{(s.technical_depth * 100).toFixed(0)}
                  </span>
                  {s.shield_score > 0.2 && (
                    <span title={`Shield: ${shieldLabel(s.shield_score)}`} class={shieldColor(s.shield_score)}>
                      S:{(s.shield_score * 100).toFixed(0)}
                    </span>
                  )}
                </div>
              </div>
              {s.analysis_summary && (
                <p class="text-xs text-text-dim mb-2 line-clamp-2 max-w-[65ch]">{s.analysis_summary}</p>
              )}
              <div class="flex items-center justify-between">
                <div class="flex flex-wrap gap-2">
                  {tags.slice(0, 4).map((tag: string) => (
                    <span class="text-xs px-2 py-1 bg-surface-hover text-text-dim rounded border border-border">
                      {tag}
                    </span>
                  ))}
                </div>
                <div class="flex gap-2 text-xs text-text-dim">
                  {s.upvotes > 0 && <span>{s.upvotes} up</span>}
                  {s.comments > 0 && <span>{s.comments} cmt</span>}
                  {s.stars > 0 && <span>{s.stars} star</span>}
                  {s.author && <span class="text-purple">{s.author}</span>}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Voices Section -->
    {voices.length > 0 && (
      <section class="mb-12">
        <h2 class="text-lg font-semibold text-text mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-purple"></span>
          Quality Voices
        </h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-3">
          {voices.map((v: any) => (
            <div class="bg-surface border border-border rounded-lg p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class={`text-xs px-2 py-1 rounded ${sourceBg(v.platform)}`}>
                  {sourceIcon(v.platform)}
                </span>
                <span class="font-medium text-sm text-text">{v.name}</span>
              </div>
              <div class="grid grid-cols-3 gap-2 text-xs">
                <div>
                  <div class="text-text-dim">Originality</div>
                  <div class="text-amber font-semibold">{(v.avg_originality * 100).toFixed(0)}%</div>
                </div>
                <div>
                  <div class="text-text-dim">Depth</div>
                  <div class="text-cyan font-semibold">{(v.avg_depth * 100).toFixed(0)}%</div>
                </div>
                <div>
                  <div class="text-text-dim">Posts</div>
                  <div class="text-text font-semibold">{v.content_count}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="border-t border-border pt-6 mt-12 text-xs text-text-dim max-w-[65ch]">
      <p>
        Undercurrent scans Hacker News, Reddit, and GitHub every 6 hours.
        Each signal is scored for AI-generated hype (psychosis filter) and genuine originality.
        Trend detection is people detection.
      </p>
      <p class="mt-2">
        Built on Cloudflare Workers + D1 + Claude Haiku.
        Data updates every 6 hours via cron trigger.
      </p>
    </footer>
  </div>

  <script>
    (function() {
      const isSetup = localStorage.getItem('undercurrent-setup-complete') === 'true';
      const cta = document.getElementById('setup-cta');
      const badgeEl = document.getElementById('stack-badge');
      const summary = document.getElementById('stack-summary');

      if (!isSetup) {
        if (cta) cta.classList.remove('hidden');
        return;
      }

      const raw = localStorage.getItem('undercurrent-stack');
      if (!raw) return;
      const stack = JSON.parse(raw);

      if (badgeEl && summary) {
        badgeEl.classList.remove('hidden');
        const parts: string[] = [];
        if (stack.building) parts.push(stack.building);
        if (stack.stack && stack.stack.length) parts.push(stack.stack.join(', '));
        summary.textContent = 'Stack: ' + parts.join(' / ');
      }

      const allTerms = [
        ...(stack.stack || []),
        ...(stack.ai_tools || []),
        ...(stack.infra || []),
        ...(stack.sources || []),
      ].map((t: string) => t.toLowerCase());

      function isRelevant(text: string): boolean {
        const lower = text.toLowerCase();
        return allTerms.some(term => lower.includes(term));
      }

      document.querySelectorAll('.bg-surface.border.border-border.rounded-lg').forEach(card => {
        const text = card.textContent || '';
        if (isRelevant(text)) {
          const tag = document.createElement('span');
          tag.className = 'text-xs px-2 py-1 bg-green/10 text-green border border-green/20 rounded-full ml-2 whitespace-nowrap';
          tag.textContent = 'relevant';
          const titleEl = card.querySelector('.text-sm.font-medium, .text-lg.font-semibold');
          if (titleEl) titleEl.after(tag);
        }
      });

      // Action approve/dismiss
      document.querySelectorAll('.action-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const el = btn as HTMLElement;
          const actionId = el.dataset.actionId;
          const verb = el.dataset.verb;
          if (!actionId || !verb) return;

          el.textContent = '...';
          el.style.pointerEvents = 'none';

          try {
            await fetch(`/api/actions/${actionId}/${verb}`, { method: 'POST' });
            const card = el.closest('.action-card');
            if (card) {
              (card as HTMLElement).style.opacity = '0.3';
              (card as HTMLElement).style.pointerEvents = 'none';
              setTimeout(() => card.remove(), 800);
            }
            const section = document.getElementById('actions-section');
            if (section) {
              const remaining = section.querySelectorAll('.action-card:not([style*="opacity"])').length;
              if (remaining <= 1) setTimeout(() => section.remove(), 900);
            }
          } catch {
            el.textContent = verb === 'approve' ? 'Approve' : 'Dismiss';
            el.style.pointerEvents = '';
          }
        });
      });

      // Kit download with stack context (POST)
      document.querySelectorAll('.kit-download').forEach(btn => {
        btn.addEventListener('click', async () => {
          const topic = (btn as HTMLElement).dataset.topic || '';
          const el = btn as HTMLElement;
          el.textContent = 'Generating...';
          el.style.pointerEvents = 'none';

          try {
            const resp = await fetch(`/api/kit?topic=${encodeURIComponent(topic)}&download=1`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ stack }),
            });
            const md = await resp.text();
            const blob = new Blob([md], { type: 'text/markdown' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            const date = new Date().toISOString().split('T')[0];
            a.download = `undercurrent-kit-${topic}-${date}.md`;
            a.click();
            URL.revokeObjectURL(url);
          } catch {
            // Fallback to GET
            window.location.href = `/api/kit?topic=${encodeURIComponent(topic)}&download=1`;
          }

          el.textContent = 'Download Kit .md';
          el.style.pointerEvents = '';
        });
      });

      // Fetch absorption scores for visible trends
      const topicEls = document.querySelectorAll('.absorption-score');
      if (topicEls.length > 0) {
        const topics = Array.from(topicEls).map(el => (el as HTMLElement).dataset.topic || '');
        fetch('/api/absorption', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ stack, topics }),
        })
          .then(r => r.json())
          .then((data: any) => {
            if (!data.scores) return;
            topicEls.forEach(el => {
              const topic = (el as HTMLElement).dataset.topic || '';
              const score = data.scores[topic];
              if (score !== undefined) {
                const color = score >= 70 ? 'text-green' : score >= 40 ? 'text-amber' : 'text-text-dim';
                (el as HTMLElement).className = `text-xs ${color}`;
                (el as HTMLElement).textContent = `absorption: ${score}%`;
                el.classList.remove('hidden');
              }
            });
          })
          .catch(() => {});
      }
    })();
  </script>
</Layout>
